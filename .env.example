# ─── Demo mode ────────────────────────────────────────────────────────
# Set both to "true" for hackathon demo (no real commands execute).
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ─── Optional: real LLM / STT (only needed if DEMO_MODE=false) ────────
# OPENAI_API_KEY=sk-...          # used by /api/transcribe and /api/plan
# OPENAI_MODEL=gpt-4o-mini       # default model for plan generation
# OPENAI_STT_MODEL=whisper-1     # default model for speech-to-text

# ─── Optional: target repo path for live command execution ────────────
# VOICEOPS_TARGET_DIR=/absolute/path/to/your/project
