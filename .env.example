# ─── Demo mode ────────────────────────────────────────────────────────
# Set both to "true" for hackathon demo (no real commands execute).
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ─── Optional: real LLM / STT (only needed if DEMO_MODE=false) ────────
# OPENAI_API_KEY=sk-...          # used by /api/transcribe and /api/plan
# OPENAI_MODEL=gpt-4o-mini       # default model for plan generation
# OPENAI_STT_MODEL=whisper-1     # default model for speech-to-text

# ─── Optional: target repo path for live command execution ────────────
VOICEOPS_TARGET_DIR=/absolute/path/to/your-buggy-demo-repo

# ─── Optional evaluator provider ──────────────────────────────────────────
# local = built-in deterministic evaluator
# cekura = attempt Cekura external evaluation, fallback to local if unavailable
EVALUATOR_PROVIDER=local

# Optional Cekura config
CEKURA_API_KEY=
CEKURA_BASE_URL=
CEKURA_AGENT_ID=
CEKURA_SCENARIO_ID=repo_pre_push_safety
